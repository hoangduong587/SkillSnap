@page "/register"
@using SkillSnap.Client.Auth

@inject AuthService AuthService
@inject NavigationManager Nav
@inject CustomAuthStateProvider AuthStateProvider

<h3 class="mt-4">Create an Account</h3>

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger">@ErrorMessage</div>
}

<div class="card p-4 shadow-sm" style="max-width: 450px;">
    <EditForm Model="registerModel" OnValidSubmit="HandleRegister">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label>Name</label>
            <InputText class="form-control" @bind-Value="registerModel.Name" />
        </div>

        <div class="mb-3">
            <label>Email</label>
            <InputText class="form-control" @bind-Value="registerModel.Email" />
        </div>

        <div class="mb-3">
            <label>Password</label>
            <InputText type="password" class="form-control" @bind-Value="registerModel.Password" />
        </div>

        <button class="btn btn-success w-100" disabled="@isLoading">
            @(isLoading ? "Creating account..." : "Register")
        </button>
    </EditForm>
</div>

@code {
    private RegisterDto registerModel = new();
    private string ErrorMessage = "";
    private bool isLoading = false;

    private async Task HandleRegister()
    {
        ErrorMessage = "";
        isLoading = true;

        // AuthService.Register now returns the token
        var token = await AuthService.Register(registerModel);

        if (!string.IsNullOrEmpty(token))
        {
            // Notify Blazor authentication system
            await AuthStateProvider.NotifyUserAuthentication(token);

            // Force reload so HttpClient + AppState refresh
            Nav.NavigateTo("/", forceLoad: true);
        }
        else
        {
            ErrorMessage = "Registration failed. Email may already be in use.";
        }

        isLoading = false;
    }
}
