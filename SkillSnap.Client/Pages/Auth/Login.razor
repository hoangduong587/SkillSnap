@page "/login"
@using SkillSnap.Client.Auth

@inject AuthService AuthService
@inject NavigationManager Nav
@inject CustomAuthStateProvider AuthStateProvider
@using SkillSnap.Client.Auth


<h3 class="mt-4">Login</h3>

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger">@ErrorMessage</div>
}

<div class="card p-4 shadow-sm" style="max-width: 400px;">
    <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label>Email</label>
            <InputText class="form-control" @bind-Value="loginModel.Email" />
        </div>

        <div class="mb-3">
            <label>Password</label>
            <InputText type="password" class="form-control" @bind-Value="loginModel.Password" />
        </div>

        <button class="btn btn-primary w-100" disabled="@isLoading">
            @(isLoading ? "Logging in..." : "Login")
        </button>
    </EditForm>
</div>

@code {
    private LoginDto loginModel = new();
    private string ErrorMessage = "";
    private bool isLoading = false;

    private async Task HandleLogin()
    {
        ErrorMessage = "";
        isLoading = true;

        // AuthService.Login() now returns the token
        var token = await AuthService.Login(loginModel);

        if (!string.IsNullOrEmpty(token))
        {
            // Notify Blazor authentication system
            await AuthStateProvider.NotifyUserAuthentication(token);

            // Force reload so HttpClient + AppState refresh
            Nav.NavigateTo("/", forceLoad: true);
        }
        else
        {
            ErrorMessage = "Invalid email or password.";
        }

        isLoading = false;
    }
}
